# Postgres connection for Prisma (matches docker-compose.yml)
DATABASE_URL="postgresql://seeky:seeky@localhost:5432/seeky?schema=public"

# Server port
PORT=3000

# Geoapify API key — candidate region polygons (Boundaries API) + fallback
# employer autocomplete. Leave empty to use the built-in offline fallback cities.
# Get a free key at https://www.geoapify.com/
GEOAPIFY_API_KEY=

# Google Maps Platform key — employer location autocomplete (Places API +
# Geocoding/Place Details). Requires "Places API" enabled on the key.
# Leave empty to fall back to Geoapify for the employer point too.
GOOGLE_MAPS_API_KEY=
